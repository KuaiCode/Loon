#!name=WeTalk + PingMe 自动化签到+视频奖励
#!desc=WeTalk 和 PingMe 的 Loon 合并插件版。
#!author = ZenmoFeiShi[https://github.com/ZenmoFeiShi],KuaiCode[https://github.com/KuaiCode]
#!homepage = https://github.com/ZenmoFeiShi/Qx
#!date = 2026-05-17

[Script]
http-request ^https:\/\/api\.wetalkapp\.com\/app\/queryBalanceAndBonus script-path=https://raw.githubusercontent.com/KuaiCode/Loon/main/JavaScript/WeTalk.js,tag=WeTalk参数抓取,enable=true
cron "20 8,20 * * *" script-path=https://raw.githubusercontent.com/KuaiCode/Loon/main/JavaScript/WeTalk.js,tag=WeTalk签到,enable=true
http-request ^https:\/\/api\.pingmeapp\.net\/app\/queryBalanceAndBonus script-path=https://raw.githubusercontent.com/KuaiCode/Loon/main/JavaScript/PingMe.js,tag=PingMe参数抓取,enable=true
cron "30 8,20 * * *" script-path=https://raw.githubusercontent.com/KuaiCode/Loon/main/JavaScript/PingMe.js,tag=PingMe签到,enable=true

[MITM]
hostname = api.wetalkapp.com,api.pingmeapp.net
